{
  "name": "cofrap-front",
  "version": "2026.4.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint .",
    "format": "prettier --write --experimental-cli src/",
    "format:check": "prettier --check src/",
    "check:i18n": "tsx scripts/check-i18n.ts",
    "check:bundle-size": "node scripts/check-bundle-size.mjs",
    "check:all": "yarn lint && yarn format:check && yarn type-check && yarn check:i18n && yarn build && yarn check:bundle-size"
  },
  "dependencies": {
    "@lucide/vue": "^1.16.0",
    "axios": "^1.16.0",
    "jsqr": "^1.4.0",
    "otpauth": "^9.5.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.4.0",
    "eslint-plugin-vue": "^10.9.1",
    "npm-run-all2": "^9.0.1",
    "prettier": "3.8.3",
    "sass": "^1.99.0",
    "tsx": "^4.20.0",
    "typescript": "~6.0.0",
    "vite": "^8.0.8",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
